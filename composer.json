{
    "name": "sarh/attendance-system",
    "description": "Production-grade MVC attendance system",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "monolog/monolog": "^3.5",
        "predis/predis": "^2.2",
        "phpmailer/phpmailer": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "includes/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true
    }
}
